      "text": "x / (a/b) = x * b/a\n\n10 / (2 1/2) = 10 / (5/2) = 10 * (2/5) = 10 * 2 / 5 = 4",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "x / (a/b) = x * b/a\n\n10 / (2 1/2) = 10 / (5/2) = 10 * (2/5) = 10 * 2 / 5 = 4",
      "autoResize": true,
      "lineHeight": 1.25
    },
